{
  "name": "younovate-lms-backend",
  "version": "3.0.0",
  "description": "Younovate LMS — Complete REST API with LiveKit, Socket.io, S3, SMTP",
  "main": "src/server.js",
 "scripts": {
  "dev": "nodemon src/server.js",
  "start": "node src/server.js",
