  "setup": "npm run seed && npm run yiep && npm run start"
},
  "dependencies": {
    "bcryptjs":             "^3.0.3",
    "cookie-parser":        "^1.4.7",
    "cors":                 "^2.8.6",
    "dotenv":               "^16.6.1",
    "express":              "^4.19.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit":   "^7.5.1",
    "express-validator":    "^7.2.0",
    "helmet":               "^7.2.0",
    "jsonwebtoken":         "^9.0.0",
    "livekit-server-sdk":   "^2.5.0",
    "mongoose":             "^8.23.1",
    "morgan":               "^1.10.1",
    "multer":               "^1.4.5-lts.1",
    "nodemailer":           "^8.0.7",
    "socket.io":            "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
