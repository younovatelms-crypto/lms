# backend/.env.example
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas
#MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/

MONGODB_URI="mongodb://127.0.0.1:27017/younovate"
# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# LiveKit — from livekit.io cloud dashboard
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# AWS S3 (for assignment uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Cloudflare Stream (for session recordings)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

/*
# SMTP — Gmail example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=rohithprogrammer@gmail.com
SMTP_PASS=pffylamydvegjxps
SMTP_FROM=rohithprogrammer@gmail.com




 
# For production use SendGrid / Resend / AWS SES instead:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx
